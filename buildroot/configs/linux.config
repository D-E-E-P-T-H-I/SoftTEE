# Minimal Linux kernel config for QEMU aarch64 virt machine
# with PEX module support
#
# Based on: make ARCH=arm64 defconfig, then trimmed.
# Use this as a starting point; Buildroot's kernel build will
# merge defaults for anything not set here.

# ── General ──
CONFIG_LOCALVERSION="-pex"
CONFIG_DEFAULT_HOSTNAME="pex-linux"
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_BPF_SYSCALL=y
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_MULTIUSER=y
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_TMPFS=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y

# ── Platform ──
CONFIG_ARCH_VIRT=y
CONFIG_ARM64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# ── Module support (required for pex.ko) ──
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y
CONFIG_MODVERSIONS=y

# ── Memory management ──
CONFIG_MMU=y
CONFIG_PAGE_SIZE_4KB=y
CONFIG_SPARSEMEM=y
CONFIG_COMPACTION=y

# ── Block and filesystem ──
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y
CONFIG_EXT2_FS=y
CONFIG_EXT4_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Networking (minimal for DHCP) ──
CONFIG_NET=y
CONFIG_INET=y
CONFIG_VIRTIO_NET=y

# ── Serial / Console ──
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_TTY=y
CONFIG_PRINTK=y

# ── Virtio (for QEMU virt machine) ──
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_HW_RANDOM_VIRTIO=y

# ── PCI (needed for virtio-pci) ──
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y

# ── Debug / tracing (useful for PEX demos) ──
CONFIG_DYNAMIC_DEBUG=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_DEBUG_FS=y

# ── Misc ──
CONFIG_COMPAT=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_UNIX=y
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PL031=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y
